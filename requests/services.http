@baseUrl = http://localhost:3000
@serviceId = 69ce0c63fd13bbf757df72c3

### Create a service
POST {{baseUrl}}/services
Content-Type: application/json

{
  "name": "Thai Beauty",
  "durationMinutes": 40,
  "price": 1300,
  "category": "beauty"
}

### Create another service (different category)
POST {{baseUrl}}/services
Content-Type: application/json

{
  "name": "Morning Meditation",
  "description": "Guided mindfulness session",
  "durationMinutes": 45,
  "price": 350,
  "category": "meditation"
}

### Get all services
GET {{baseUrl}}/services

### Get one service (replace @serviceId at the top)
GET {{baseUrl}}/services/{{serviceId}}

### Update a service (partial — only price changes)
PATCH {{baseUrl}}/services/{{serviceId}}
Content-Type: application/json

{
  "price": 900
}

### Deactivate a service
PATCH {{baseUrl}}/services/{{serviceId}}
Content-Type: application/json

{
  "isActive": false
}

### Delete a service
DELETE {{baseUrl}}/services/{{serviceId}}

### 404 — non-existent ObjectId
GET {{baseUrl}}/services/000000000000000000000000

### 400 — invalid body (missing required fields)
POST {{baseUrl}}/services/
Content-Type: application/json

{
  "name": "Bad Request"
}

### 400 — invalid enum value
POST {{baseUrl}}/services
Content-Type: application/json

{
  "name": "Invalid Category",
  "durationMinutes": 30,
  "price": 200,
  "category": "yoga"
}

### Get inactive services
GET {{baseUrl}}/services/inactive

### Get services with no isActive field
GET {{baseUrl}}/services/no-active-field

### Filter by single category
GET {{baseUrl}}/services/filter/category?category=massage

### Filter by single category — 400 invalid enum
GET {{baseUrl}}/services/filter/category?category=yoga

### Filter by multiple categories
GET {{baseUrl}}/services/filter/categories?categories=massage,meditation

### Filter by multiple categories — 400 one invalid
GET {{baseUrl}}/services/filter/categories?categories=massage,yoga

### Filter by multiple categories — 400 trailing comma
GET {{baseUrl}}/services/filter/categories?categories=massage,

### Filter by multiple categories — 400 missing param
GET {{baseUrl}}/services/filter/categories

### Exclude a category
GET {{baseUrl}}/services/filter/category/exclude?category=retreat

### Exclude a category — 400 invalid enum
GET {{baseUrl}}/services/filter/category/exclude?category=yoga

### Filter by minimum price
GET {{baseUrl}}/services/filter/price/min?min=500

### Filter by price range
GET {{baseUrl}}/services/filter/price/range?min=300&max=1300

### Filter by price range — 400 non-numeric
GET {{baseUrl}}/services/filter/price/range?min=abc&max=900
